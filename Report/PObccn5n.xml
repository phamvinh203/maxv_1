<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
declare @d int, @m int, @y int, @m2 nvarchar(511)
select @d = day(getDate()), @m = month(getDate()), @y = year(getDate()), @m2 = datename(month, getDate())
select @$ngay_hd1 as date_from, @$ngay_hd2 as date_to, @$tk as tk, case when @@language = 'v' then ten_tk else ten_tk2 end as ten_tk
  , @d as d, @m as m, @m2 as m2, @y as y from dmtk where tk = @$tk
exec pr_SObccn1nExport @$ngay_ht1, @$ngay_ht2, @$ngay_hd1, @$ngay_hd2, @$tk, @$isbalance, @$ma_dvcs, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'SOBCCN1N%'
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile="SObccn5n_110" templateFile="" commandArgument="pdf" urlImage="&p;">
      <header v="Bảng xác nhận công nợ nhiều nhà cung cấp" e="Suppliers AR/AP Confirmation Sheet"></header>
      <download>
        <header v="Bảng xác nhận công nợ nhiều nhà cung cấp" e="Suppliers AR/AP Confirmation Sheet"/>
      </download>&b;
    </form>
    <form id="210" reportFile="SObccn5n_110" templateFile="" commandArgument="pdf" urlImage="">
