<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY Controller "APTran">
  <!ENTITY VoucherCode "HM2">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
  <!ENTITY bi "../images/bilingual.png">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
declare @formTypeAP tinyint
if @@form in ('030', '040') set @formTypeAP = 1 else set @formTypeAP = 0
if @@form in ('110','210') begin
	exec pr_Pocthm2PrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs, @formTypeAP, 1, @@language, @@userID, @@admin, '@@sysDatabaseName'
	Update dmprint set stt_rec_key='' where ma_ct like 'HM2%'
end
if @@form = '810' or @@form = '820' begin
  exec pr_Pocthm2PrintExport2 @$ngay_ct1, @$ngay_ct2, @$ma_dvcs,'HM2', @formTypeAP, 1, @@language, @@userID, @@admin, '@@sysDatabaseName'
  Update dmprint set stt_rec_key='' where ma_ct like 'HM2%'
end
if @@form in ('150','160') begin
	exec pr_Pocthm2PCPrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs, '1', @@language, @@userID, @@admin
	Update dmprint set stt_rec_key='' where ma_ct like 'HM1%'
	end
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile ="Pocthm2Print_110" templateFile="" commandArgument="Pdf" urlImage="&p;">
      <header v="Hóa đơn mua hàng dịch vụ" e="Service Purchase Invoice"/>
      <download>
        <header v="Hóa đơn mua hàng dịch vụ" e="Service Purchase Invoice"/>
      </download>&b;
    </form>
    <form id="210" reportFile ="Pocthm2Print_110" templateFile="" commandArgument="Pdf">
      <header v="Hóa đơn mua hàng dịch vụ ngoại tệ" e="Service Purchase Invoice in Foreign Currency"/>
      <download>
        <header v="Hóa đơn mua hàng dịch vụ ngoại tệ" e="Service Purchase Invoice in Foreign Currency"/>
      </download>&f;
    </form>
&s;	

    <form id="810" reportFile ="Pocthm2Print_810" templateFile="" commandArgument="Pdf" urlImage="&p;">
      <header v="Chứng từ hạch toán" e="General Ledger Voucher"/>
      <download>
        <header v="Chứng từ hạch toán" e="General Ledger Voucher"/>
      </download>&b;
		<fields>
	      <field name="title" type ="String">
			<header v="CHỨNG TỪ HẠCH TOÁN" e="General Ledger Voucher"/>
		</field>
		</fields>
    </form>
    <form id="820" reportFile ="Pocthm2Print_810" templateFile="" commandArgument="Pdf">
      <header v="Chứng từ hạch toán ngoại tệ" e="General Ledger Voucher in Foreign Currency"/>
      <download>
        <header v="Chứng từ hạch toán ngoại tệ" e="General Ledger Voucher in Foreign Currency"/>
      </download>&f;
		<fields>
	      <field name="title" type ="String">
			<header v="CHỨNG TỪ HẠCH TOÁN" e="General Ledger Voucher"/>
		</field>
		</fields>
	
    </form>
	
  </forms>

