      </download>&f;
    </form>

    &s;

    <form id="510" reportFile="" templateFile="GRTran_110" commandArgument="Excel" urlImage="&e;">
      <header v="Hóa đơn dịch vụ trả lại dạng (Excel)" e="Services Sale Return Invoice (Excel)"></header>
      <download>
        <header  v="Hóa đơn dịch vụ trả lại" e="Services Sale Return Invoice"/>
      </download>&b;
    </form>
    <form id="610" reportFile="" templateFile="GRTran_210" commandArgument="Excel">
      <header v="Hóa đơn  dịch vụ trả lại ngoại tệ (Excel)" e="Services Sale Return Invoice in Foreign Currency (Excel)"/>
      <download>
        <header  v="Hóa đơn dịch vụ trả lại tiền ngoại tệ" e="Services Sale Return Invoice in Foreign Currency"/>
      </download>&f;
    </form>

    &s;

    &GLTranReport;
  </forms>

