<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
	<query>
		<text>
		  <![CDATA[
				exec pr_GLTranPrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs, @@language, @@userID, @@admin	
				Update dmprint set stt_rec_key='' where ma_ct like 'PK%1'
			]]>
		</text>
	</query>

	<forms>
		<form id="110" reportFile="GLTRanPrint_110" templateFile="" commandArgument="Pdf" urlImage="&p;">
		  <header v="Phiếu kế toán tổng hợp" e="Cash Receipt"></header>
		  <download>
			<header  v="Phiếu kế toán tổng hợp" e="Cash Receipt"/>
		  </download>&b;
		</form>
		<form id="210" reportFile="GLTRanPrint_110" templateFile="" commandArgument="Pdf">
		  <header v="Phiếu kế toán tổng hợp tiền ngoại tệ" e="Cash Receipt in Foreign Currency"/>
		  <download>
			<header  v="Phiếu kế toán tổng hợp tiền ngoại tệ" e="Cash Receipt in Foreign Currency"/>
		  </download>&f;
		</form>
	</forms>

	<fields>
		<field name="title" type="String">
			<header v="PHIẾU KẾ TOÁN TỔNG HỢP" e="GENERAL VOUCHER"/>
		</field>
		<field name="h_so_phieu" type="String">
			<header v="Số phiếu: " e="Voucher No.: "/>
		</field>
		<field name="h_space" type="String">
			<header v=" " e=""/>
		</field>

		<field name="h_dien_giai" type="String">
			<header v="Diễn giải " e="Description"/>
		</field>
		<field name="h_vu_viec" type="String">
			<header v="Dự án " e="Project"/>
		</field>
		<field name="h_tk" type="String">
			<header v="Tài khoản " e="Account"/>
		</field>
		<field name="h_phat_sinh_no" type="String">
			<header v="Phát sinh nợ " e="Debit Amount"/>
		</field>
		<field name="h_phat_sinh_co" type="String">
			<header v="Phát sinh có " e="Credit Amount"/>
		</field>

		<field name="h_tt_bang_chu" type="String">
			<header v="Bằng chữ: " e="In Words:"/>
		</field>
	</fields>
</report>