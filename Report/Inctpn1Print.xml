<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">

]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
exec pr_Inctpn1PrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'PN1%'
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile="Inctpn1Print_110" templateFile="" commandArgument="Pdf" urlImage="&p;">
      <header v="Phiếu nhập kho" e="Receiving Transaction"/>
      <download >
        <header v="Phiếu nhập kho" e="Receiving Transaction"/>
      </download>&b;
    </form>
&s;
  </forms>

  <fields>
    <field name="title" type="String">
      <header v="PHIẾU NHẬP KHO" e="RECEIVING TRANSACTION"/>
    </field>

    <field name="h_nguoi_giao_hang" type="String">
      <header v="Họ và tên người giao hàng:" e="Deliverer's Full Name:"/>
    </field>
    <field name="h_theo" type="String">
      <header v="Theo:............................................."
              e="According to:....................................."/>
    </field>
    <field name="h_so" type="String">
      <header v="số:................ "
              e="No.:................ "/>
    </field>
    <field name="h_ngay" type="String">
      <header v="ngày ..............tháng..........năm............ của..............................................................................................................................................................................."
              e="Date:.............................................. of............................................................................................................................................................................."/>
    </field>
    <field name="h_nhap_tai_kho" type="String">
      <header v="Nhập tại kho:" e="Receiving Site:"/>
    </field>
    <field name="h_dia_diem" type="String">
      <header v="Địa điểm:" e="Location:"/>
    </field>

    <field name="h_so_ct" type="String">
      <header v="Số:" e="No.:"/>
    </field>
    <field name="h_no" type="String">
      <header v="Nợ:"
              e="Debit:"/>
    </field>
    <field name="h_co" type="String">
      <header v="Có:"
              e="Credit:"/>
    </field>

    <field name="h_stt" type="String">
      <header v="Stt" e="No."/>
    </field>
    <field name="h_ma_vt" type="String">
      <header v="Mã hàng" e="Item Code"/>
    </field>
    <field name="h_ten_vt" type="String">
      <header v="Tên mặt hàng" e="Item Name"/>
    </field>
    <field name="h_dvt" type="String">
      <header v="Đvt" e="UOM"/>
    </field>
    <field name="h_so_luong" type="String">
      <header v="Theo CT" e="Quantity"/>
    </field>
    <field name="h_gia" type="String">
      <header v="Giá" e="Price"/>
    </field>
    <field name="h_tien" type="String">
      <header v="Tiền" e="Amount"/>
    </field>
    <field name="h_chung_tu" type="String">
      <header v="Chứng từ" e="In Voucher"/>
    </field>
    <field name="h_thuc_nhap" type="String">
      <header v="Thực nhập" e="Receiving"/>
    </field>

    <field name="h_xac_nhan" type="String">
      <header v="Số tiền (viết bằng chữ):" e="Amount (in Words):"/>
    </field>
    <field name="h_ct_goc" type="String">
      <header v="Số chứng từ gốc kèm theo:" e="No. of Original Document(s)"/>
    </field>
    <field name="h_don_vi" type ="String">
      <header v="Đơn vị:" e="Company:"/>
    </field>
    <field name="h_dia_chi" type ="String">
      <header v="Địa chỉ:" e="Address:"/>
    </field>
  </fields>
</report>