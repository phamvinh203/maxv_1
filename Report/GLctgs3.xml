<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
select @$so_ctgs_goc as so_ctgs_goc
exec pr_GLctgs3Export @$tu_ngay, @$den_ngay, @$keys, @$ma_dvcs, @@language, @@userID, @@admin
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile ="GLctgs3_110" commandArgument="pdf" urlImage="&p;">
      <header v="Chứng từ ghi sổ" e="Journal Voucher"/>
      <download>
        <header v="Chứng từ ghi sổ" e="Journal Voucher"/>
      </download>&b;
    </form>

    <form id="210" reportFile ="GLctgs3_110" commandArgument="pdf">
      <header v="Chứng từ ghi sổ ngoại tệ" e="Journal Voucher in Foreign Currency"/>
      <download>
        <header v="Chứng từ ghi sổ ngoại tệ" e="Journal Voucher in Foreign Currency"/>
      </download>&f;
    </form>
  </forms>

  <fields>
    <field name="title" type ="String">
      <header v="CHỨNG TỪ GHI SỔ" e="JOURNAL VOUCHER"/>
    </field>
    <field name="h_trich_yeu" type="String">
      <header v="Trích yếu" e="Description"/>
    </field>
    <field name="h_so_hieu_tk" type="String">
      <header v="Số hiệu tài khoản" e="Account"/>
    </field>
    <field name="h_no" type="String">
      <header v="Nợ" e="Debit"/>
    </field>
    <field name="h_co" type="String">
      <header v="Có" e="Credit"/>
    </field>
    <field name="h_so_tien" type="String">
      <header v="Số tiền" e="Amount"/>
    </field>
    <field name="h_ghi_chu" type="String">
      <header v="Ghi chú" e="Note"/>
    </field>
    <field name="h_ngay" type="String">
      <header v="Ngày" e="Date"/>
    </field>
    <field name="h_thang" type="String">
      <header v="tháng" e="/"/>
    </field>
    <field name="h_nam" type="String">
      <header v="năm" e="/"/>
    </field>
    <field name="h_so" type="String">
      <header v="Số" e="Batch Number"/>
    </field>
    <field name="h_so_ct_goc" type="String">
      <header v="Kèm theo" e="Enlose"/>
    </field>
    <field name="h_so_ct_kt" type="String">
      <header v="số chứng từ gốc" e="Original Voucher(s)"/>
    </field>
    <field name="h_line1" type="String">
      <header v="Mẫu số S02a-DN" e="S02a-DN Form"/>
    </field>
    <field name="h_line2" type="String">
      <header v="(Ban hành theo QĐ" e="(According to Decision"/>
    </field>
    <field name="h_line3" type="String">
      <header v="số 15/2006/QĐ-BTC ngày 20/03/2006" e="No. 15/2006/QD-BTC Dated 26 March 2006"/>
    </field>
    <field name="h_line4" type="String">
      <header v="của Bộ trưởng BTC)" e="of The Ministry Of Finance)"/>
    </field>
  </fields>
</report>