  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
if @@form = '013' or @@form = '014' begin  
  exec pr_PrintSPTranMultiCopies @stt_rec, @@id, 'm25$$partition$current', 'd25$$partition$current', @@language, @@userID, @@admin
  return
end
]]>&GLTranReportSql;<![CDATA[
else begin
  declare @m_ma_nt0 varchar(10), @key varchar(128)
  select @m_ma_nt0 = val from options where name = N'm_ma_nt0'  
      select case when a.ong_ba <> '' then rtrim(a.ong_ba) else '' end as ong_ba,
          rtrim(a.ma_kh) as ma_kh, case when @@language = 'V' then rtrim(b.ten_kh) else rtrim(b.ten_kh2) end as ten_kh, b.ten_kh2 as ten_kh2, 
          rtrim(e.dia_chi) as dia_chi, rtrim(a.dien_giai) as dien_giai, a.so_seri, ltrim(a.so_ct) so_ct, 
          rtrim(a.tk) as tk, case when @@language = 'V' then rtrim(c.ten_tk) else rtrim(c.ten_tk2) end as ten_tk, 
          a.t_tien2, a.t_tien_nt2, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt,
	        dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tt, @@language) as t_tien_in_word, 
	        dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tt_nt, @@language) as t_tien_nt_in_word,
	        replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam
        from @@prime$partition$current a with(nolock)
	        left join dmkh b with(nolock) on a.ma_kh = b.ma_kh		        
	        left join dmtk c with(nolock) on a.tk = c.tk
          left join ctgt21 e with(nolock) on a.stt_rec = e.stt_rec            
        where a.stt_rec = @stt_rec

      select @key = 'a.stt_rec = ''' + @stt_rec + ''''
      exec pr_PrintSPTran @@language, @key, 'd25$$partition$current', @@id


end
		]]>
    </text>
  </query>

