<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
declare @m_ma_nt0 varchar(10), @key varchar(128)
select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
select a.ma_kh, case when upper(@@language) = 'V' then b.ten_kh else b.ten_kh2 end as ten_kh, b.dia_chi, c.han_tt
  , case when upper(@@language) = 'V' then c.ten_tt else c.ten_tt2 end as ten_tt
  , case when upper(@@language) = 'V' then e.ten_nvbh else e.ten_nvbh2 end as ten_nvbh
	, a.so_ct, a.ma_nt, a.t_tien2, a.t_tien_nt2, a.t_ck, a.t_ck_nt, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt, a.dien_giai, (a.t_tien2 - a.t_ck) as t_tien_ck, (a.t_tien_nt2 - a.t_ck_nt) as t_tien_ck_nt
  , dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tien2, @@language) as t_tt_in_word
  ,	dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tien_nt2, @@language) as t_tt_nt_in_word
  , replace(str(day(a.ngay_ct),2),' ','0') day, replace(str(month(a.ngay_ct),2),' ','0') month, cast(year(a.ngay_ct) as char(4)) year
  , a.dia_diem_giao, a.t_so_luong
from @@prime$partition$current a with(nolock)
  left join dmkh b with(nolock) on a.ma_kh = b.ma_kh 
  left join dmtt c with(nolock) on a.ma_tt = c.ma_tt
  left join dmnvbh e with(nolock) on a.ma_nvbh = e.ma_nvbh
where a.stt_rec = @stt_rec

select @key = 'a.stt_rec = ''' + @stt_rec + ''''
exec pr_PrintSOTran @@language, @key, 'd64$$partition$current', @@id
select cast(null as image) as logo, 'Logo.png' as file_name
		]]>
    </text>
  </query>

  <forms>
