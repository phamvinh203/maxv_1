  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
]]>&GLTranReportSql;<![CDATA[
else begin
    declare @m_ma_nt0 varchar(10), @key varchar(128)
    select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
    
	declare @ma_tt nvarchar(16), @so_tt nvarchar(255), @so_tt2 nvarchar(255), @ngay_tt nvarchar(255), @ngay_tt2 nvarchar(255), @ten_bc nvarchar(255), @ten_bc2 nvarchar(255)
     select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
	select @ma_tt = rtrim(ltrim(val)) from options where name='r_cdkt'
	select @so_tt=so_tt, @so_tt2 = so_tt2, @ngay_tt = ngay_tt, @ngay_tt2 = ngay_tt2 from report1 where ma_tt=@ma_tt 
	select @ten_bc = ten_bc, @ten_bc2=ten_bc2 from report2 where ma_tt=@ma_tt and sysid='ISTran'
	
      -- Lay tk_vt trong dmvt cach nhau bang dau ','
        create table #dmtkvt(tk_vt nvarchar(64))
        insert into #dmtkvt select distinct tk_vt from @@prime$partition$current a with(nolock)
		    left join d86$$partition$current b with(nolock) on (a.stt_rec = b.stt_rec) where a.stt_rec = @stt_rec
	   
        declare @tk_vt nvarchar(64) = '', @ma_kho nvarchar(16) = '', @ten_kho nvarchar(128) = '', @ten_kho2 nvarchar(128) = ''
        select @tk_vt = @tk_vt + ', ' + LTRIM(RTRIM(tk_vt)) from #dmtkvt
        select @tk_vt = LTRIM(RIGHT(@tk_vt, LEN(@tk_vt) - 1))
        drop table #dmtkvt
        
        select top 1 @ma_kho = a.ma_kho, @ten_kho = b.ten_kho 
        from d86$$partition$current a left join dmkho b with(nolock) on a.ma_kho = b.ma_kho
        where stt_rec = @stt_rec
    
        select a.ong_ba, ltrim(rtrim(a.ma_kh)) as ma_kh, b.ten_kh, b.ten_kh2, b.dia_chi, ltrim(a.so_ct) so_ct,
		        a.dien_giai, rtrim(a.ma_nx) as ma_nx, a.t_tien, a.t_tien_nt, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt,f.ten_tk,
		        dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tt, @@language) as t_tt_in_word, 
		        dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tt_nt, @@language) as t_tt_nt_in_word,
		        replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam,
            @tk_vt as tk_vt, @ma_kho as ma_kho, @ten_kho as ten_kho, @ten_kho2 as ten_kho2, a.tk,
			@so_tt as so_tt, @so_tt2 as so_tt2, @ngay_tt as ngay_tt, @ngay_tt2 as ngay_tt2, @ten_bc as ten_bc, @ten_bc2 as ten_bc2
	        from @@prime$partition$current a with(nolock)
		        left join dmkh b with(nolock) on a.ma_kh = b.ma_kh
            	LEFT JOIN dbo.dmtk f with(nolock) ON f.tk = a.ma_nx
	        where a.stt_rec = @stt_rec

        select @key = 'a.stt_rec = ''' + @stt_rec + ''''
        exec pr_PrintPSTran @@language, @key, 'd86$$partition$current', @@id
end
		]]>
    </text>
  </query>

