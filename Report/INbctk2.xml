<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <forms>
    <form id="100" reportFile="INbctk2_100" templateFile="" commandArgument="Pdf" urlImage="&p;">
      <header v="Báo cáo nhập xuất tồn (số lượng)" e="Stock Summary Only Quantity"></header>
      <download>
        <header  v="Báo cáo nhập xuất tồn (số lượng)" e="Stock Summary Only Quantity"/>
      </download>
      <fields>
        <field name="isFC" type="Boolean">
          <header v="False" e="False"/>
        </field>
        <field name="h_nhap" type="String">
          <header v="nhập" e="Receipt"/>
        </field>
        <field name="h_xuat" type="String">
          <header v="xuất" e="Issue"/>
        </field>
      </fields>
    </form>

    <form id="110" reportFile="INbctk2_110" templateFile="" commandArgument="Pdf">
      <header v="Báo cáo nhập xuất tồn (số lượng và giá trị)" e="Stock Summary Quantity and Values"></header>
      <download>
        <header  v="Báo cáo nhập xuất tồn (số lượng và giá trị)" e="Stock Summary Quantity and Values"/>
      </download>
      <fields>
        <field name="isFC" type="Boolean">
          <header v="False" e="False"/>
        </field>
      </fields>
    </form>

    <form id="210" reportFile="INbctk2_110" templateFile="" commandArgument="Pdf">
      <header v="Báo cáo nhập xuất tồn ngoại tệ (số lượng và giá trị)" e="Stock Summary Quantity and Values in Foreign Currency"/>
      <download>
        <header  v="Báo cáo nhập xuất tồn ngoại tệ (số lượng và giá trị)" e="Stock Summary Quantity and Values in Foreign Currency"/>
      </download>
      <fields>
        <field name="isFC" type="Boolean">
          <header v="True" e="True"/>
        </field>
      </fields>
    </form>

    &s;

    <form id="500" reportFile="" templateFile="INbctk2_100" commandArgument="Excel" urlImage="&e;" rowFilter="[2$sysprint = 1]">
      <header v="Báo cáo nhập xuất tồn (số lượng) (Excel)" e="Stock Summary Only Quantity"></header>
      <download>
        <header  v="Báo cáo nhập xuất tồn (số lượng) (Excel)" e="Stock Summary Only Quantity"/>
      </download>
    </form>

    <form id="510" reportFile="" templateFile="INbctk2_110" commandArgument="Excel" rowFilter="[2$sysprint = 1]">
      <header v="Báo cáo nhập xuất tồn (số lượng và giá trị)" e="Stock Summary Quantity and Values"></header>
      <download>
        <header  v="Báo cáo nhập xuất tồn (số lượng và giá trị)" e="Stock Summary Quantity and Values"/>
      </download>
    </form>

    <form id="610" reportFile="" templateFile="INbctk2_210" commandArgument="Excel" rowFilter="[2$sysprint = 1]">
      <header v="Báo cáo nhập xuất tồn ngoại tệ (số lượng và giá trị)" e="Stock Summary Quantity and Values in Foreign Currency"/>
      <download>
        <header  v="Báo cáo nhập xuất tồn ngoại tệ (số lượng và giá trị)" e="Stock Summary Quantity and Values in Foreign Currency"/>
      </download>
      <fields>
        <field name="isFC" type="Boolean">
          <header v="True" e="True"/>
        </field>
        <field name="h_gia_tri" type="String">
          <header v="Giá trị nt" e="FC Amount"/>
        </field>
      </fields>
    </form>
  </forms>

  <fields>
    <field name="title" type="String">
      <header v="BÁO CÁO NHẬP XUẤT TỒN" e="STOCK SUMMARY"/>
    </field>
	
    <field name="h_kho" type="String">
      <header v="Kho: " e="Site:"/>
    </field>
	
    <field name="h_nhap" type="String">
      <header v="Nhập" e="Receipt"/>
    </field>
    <field name="h_nhap_u" type="String">
      <header v="Số lượng nhập" e="Receipt"/>
    </field>
    <field name="h_xuat" type="String">
      <header v="Xuất" e="Issue"/>
    </field>
    <field name="h_xuat_u" type="String">
      <header v="Số lượng xuất" e="Issue"/>
    </field>
    <field name="h_nt" type="String">
      <header v="nt" e="FC"/>
    </field>
    <field name="h_stt" type="String">
      <header v="Stt" e="No."/>
    </field>
    <field name="h_ma_vt" type="String">
      <header v="Mã hàng" e="Item Code"/>
    </field>
    <field name="h_ten_vt" type="String">
      <header v="Tên mặt hàng" e="Item Name"/>
    </field>
    <field name="h_dvt" type="String">
      <header v="Đvt" e="UOM"/>
    </field>
    <field name="h_tu_ngay" type="String">
      <header v="Từ ngày" e="Date from"/>
    </field>
    <field name="h_den_Ngay" type="String">
      <header v="đến ngày" e="to"/>
    </field>
    <field name="h_ton_dau" type="String">
      <header v="Tồn đầu" e="Opening"/>
    </field>
    <field name="h_ton_cuoi" type="String">
      <header v="Tồn cuối" e="Closing"/>
    </field>
    <field name="h_sl" type="String">
      <header v="Số lượng" e="Quantity"/>
    </field>
    <field name="h_gia_tri" type="String">
      <header v="Giá trị" e="Amount"/>
    </field>
    <field name="h_space" type="String">
      <header v=" " e=" "/>
    </field>
  </fields>
</report>