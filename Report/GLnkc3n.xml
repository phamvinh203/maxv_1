<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
declare @h_line1 as nvarchar(128), @h_line2 as nvarchar(128), @h_line3 as nvarchar(128),@ma_tt nvarchar(16)
select @ma_tt = rtrim(ltrim(val)) from options where name='r_cdkt'
select @h_line1 = case when @@language = 'V' then ten_bc else ten_bc2 end from report2 where sysid=']]>&Form;<![CDATA['
select @h_line2 = case when @@language = 'V' then so_tt else so_tt2 end from report1 where ma_tt=@ma_tt
select @h_line3 = case when @@language = 'V' then ngay_tt else ngay_tt2 end from report1 where ma_tt=@ma_tt

select cast(@$tu_ngay as smalldatetime) as tu_ngay, cast(@$den_ngay as smalldatetime) as den_ngay,@h_line1 as h_line1, @h_line2 as h_line2, @h_line3 as h_line3	
exec pr_GLnkc3nExport @$tu_ngay, @$den_ngay, @$ma_dvcs, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'GLNKC3N%'

]]>
    </text>
  </query>

