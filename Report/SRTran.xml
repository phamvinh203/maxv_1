  <query>
    <text>
	<![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
declare @m_ma_nt0 varchar(10), @key varchar(128)
select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
]]>&GLTranReportSql;<![CDATA[
else begin
   declare @ma_tt nvarchar(16), @so_tt nvarchar(255), @so_tt2 nvarchar(255), @ngay_tt nvarchar(255), @ngay_tt2 nvarchar(255), @ten_bc nvarchar(255), @ten_bc2 nvarchar(255)
	select @ma_tt = rtrim(ltrim(val)) from options where name='r_cdkt'
	select @so_tt=so_tt, @so_tt2 = so_tt2, @ngay_tt = ngay_tt, @ngay_tt2 = ngay_tt2 from report1 where ma_tt=@ma_tt 
	select @ten_bc = ten_bc, @ten_bc2=ten_bc2 from report2 where ma_tt=@ma_tt and sysid='IRTran'
	
	    -- Lay tk_vt trong dmvt cach nhau bang dau ','
        create table #dmtkvt(tk_vt nvarchar(64))
        insert into #dmtkvt select distinct tk_vt from @@prime$partition$current a with(nolock)
		    left join d76$$partition$current b with(nolock) on (a.stt_rec = b.stt_rec) where a.stt_rec = @stt_rec
	   
        declare @tk_vt nvarchar(128) = ''
        select @tk_vt = @tk_vt + ', ' + LTRIM(RTRIM(tk_vt)) from #dmtkvt
        select @tk_vt = LTRIM(RIGHT(@tk_vt, LEN(@tk_vt) - 1))
        drop table #dmtkvt 
		
		-- Lay ten kho
		 create table #khotmp(ma_kho varchar(16), ten_kho nvarchar(256))
        insert into #khotmp select distinct ma_kho, '' from d76$$partition$current where stt_rec = @stt_rec
		UPDATE #khotmp set ten_kho = case when @@language='v' then rtrim(a.ma_kho) + '-' + rtrim(b.ten_kho) else rtrim(a.ma_kho) + '-' + rtrim(b.ten_kho2) end from #khotmp a left join dmkho b on a.ma_kho=b.ma_kho
		
		declare @ten_kho nvarchar(4000) = ''
        select @ten_kho = @ten_kho + ', ' + LTRIM(RTRIM(ten_kho)) from #khotmp
        select @ten_kho = LTRIM(RIGHT(@ten_kho, LEN(@ten_kho) - 1))
        drop table #khotmp 
		
    select case when a.ong_ba <> '' then a.ong_ba else case when @@language = 'V' then d.ten_kh else d.ten_kh2 end end as ong_ba, 
        a.dien_giai, a.so_seri, d.ma_kh, d.ten_kh, d.ten_kh2, b.ma_kho, isnull(c.dia_chi,'') dia_diem, ltrim(a.so_ct) so_ct, 
        a.t_thue, a.t_thue_nt, a.t_tien2, a.t_tien_nt2, a.t_tt, a.t_tt_nt, a.t_tien, a.t_tien_nt,
		    dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tien, @@language) t_tien_in_word, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tien_nt, @@language) t_tien_nt_in_word,
			dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tien2, @@language) t_tien2_in_word, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tien_nt2, @@language) t_tien_nt2_in_word,
		    replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam,
			@so_tt as so_tt, @so_tt2 as so_tt2, @ngay_tt as ngay_tt, @ngay_tt2 as ngay_tt2, @ten_bc as ten_bc, @ten_bc2 as ten_bc2,
			@tk_vt as tk_no, a.tk as tk_co, @ten_kho as ten_kho
	    from @@prime$partition$current a with(nolock)
		    left join d76$$partition$current b with(nolock) on (a.stt_rec = b.stt_rec and b.stt_rec0 = (select min(stt_rec0) from d76$$partition$current with(nolock) where stt_rec = a.stt_rec))
		    left join dmkho c with(nolock) on b.ma_kho = c.ma_kho
		    left join dmkh d with(nolock) on d.ma_kh = a.ma_kh
	    where a.stt_rec = @stt_rec

    select @key = 'a.stt_rec = ''' + @stt_rec + ''''
    exec pr_PrintIRTranSRTran @@language, @key, 'd76$$partition$current', @@id

end
		]]>
    </text>
  </query>

