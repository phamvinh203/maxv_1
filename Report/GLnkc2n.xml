<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
select @$tu_ngay as tu_ngay, @$den_ngay as den_ngay, @$ngay_mo_so as ngay_mo_so
exec rs_GLnkc2nExport @$tu_ngay, @$den_ngay, @$ma_dvcs, @$nhom_tk, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'GLNKC2N%'
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile ="GLnkc2n_110" commandArgument="pdf" urlImage="&p;">
      <header v="Sổ cái nhiều tài khoản" e="Accounts Ledger"/>
      <download>
        <header v="Sổ cái nhiều tài khoản" e="Accounts Ledger"/>
      </download>&b;
    </form>

    <form id="210" reportFile ="GLnkc2n_110" commandArgument="pdf">
      <header v="Sổ cái nhiều tài khoản tiền ngoại tệ" e="Accounts Ledger in Foreign Currency"/>
      <download>
        <header v="Sổ cái nhiều tài khoản tiền ngoại tệ" e="Accounts Ledger in Foreign Currency"/>
      </download>&f;
    </form>
	&s;
	<form id="510" templateFile ="GLnkc2n_110" commandArgument="Excel" urlImage="&e;">
		<header v="Sổ cái nhiều tài khoản (Excel)" e="Accounts Ledger"></header>
		<download>
			<header v="Sổ cái nhiều tài khoản" e="Accounts Ledger"/>
		</download>
	</form>
	<form id="520" templateFile ="GLnkc2n_210" commandArgument="Excel" urlImage="&e;">
		<header v="Sổ cái nhiều tài khoản ngoại tệ (Excel)" e="Accounts Ledger in Foreign Currency"></header>
		<download>
			<header v="Sổ cái nhiều tài khoản" e="Accounts Ledger in Foreign Currency"/>
		</download>
	</form>
  </forms>

  <fields>
    <field name="title" type ="String">
      <header v="SỔ CÁI" e="LEDGER"/>
    </field>
    <field name="h_tu_ngay" type="String">
      <header v="Từ ngày" e="Date from"/>
    </field>
    <field name="h_den_ngay" type="String">
      <header v="đến ngày" e="to"/>
    </field>
    <field name="h_space" type="String">
      <header v=" " e=" "/>
    </field>
    <field name="h_separator" type="String">
      <header v="-" e="-"/>
    </field>
    <field name="h_separator1" type="String">
      <header v="," e=","/>
    </field>
    <field name="h_co" type="String">
      <header v="Có" e="Credit"/>
    </field>
    <field name="h_ct" type="String">
      <header v="Chứng từ" e="Voucher"/>
    </field>
    <field name="h_dien_giai" type="String">
      <header v="Diễn giải" e="Description"/>
    </field>
    <field name="h_ngay_thang_ghi_so" type="String">
      <header v="Ngày tháng ghi sổ" e="Posting Date"/>
    </field>
    <field name="h_nhat_ky_chung" type="String">
      <header v="Nhật ký chung" e="General Journal"/>
    </field>
    <field name="h_trang_so" type="String">
      <header v="Trang sổ" e="Page"/>
    </field>
    <field name="h_stt_dong" type="String">
