    </field>
    <field name="r_ma_nt" type="String">
      <header v="Mã nt:" e="FC Code:"/>
    </field>
    <field name="r_ma_ntx" type="String">
      <header v="Mã nt:" e="FC Code:"/>
    </field>
    <field name="r_sd_co_ck" type="String">
