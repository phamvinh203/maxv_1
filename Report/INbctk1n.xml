  <query>
    <text>
      <![CDATA[
declare @name nvarchar(1023)
select @name = case when @@language = 'V' then ten_kho else ten_kho2 end from dmkho where ma_kho = @$ma_kho
	declare @ma_tt nvarchar(16), @so_tt nvarchar(255), @so_tt2 nvarchar(255), @ngay_tt nvarchar(255), @ngay_tt2 nvarchar(255), @ten_bc nvarchar(255), @ten_bc2 nvarchar(255)
	select @ma_tt = rtrim(ltrim(val)) from options where name='r_cdkt'
	select @so_tt=so_tt, @so_tt2 = so_tt2, @ngay_tt = ngay_tt, @ngay_tt2 = ngay_tt2 from report1 where ma_tt=@ma_tt 
	select @ten_bc = ten_bc, @ten_bc2=ten_bc2 from report2 where ma_tt=@ma_tt and upper(sysid) = 'INBCTK1N'
	
select cast(@$tu_ngay as smalldatetime) as date_from, cast(@$den_ngay as smalldatetime) as date_to, @$ma_kho as ma_kho, @name as ten_kho,	
	@so_tt as so_tt, @so_tt2 as so_tt2, @ngay_tt as ngay_tt, @ngay_tt2 as ngay_tt2, @ten_bc as ten_bc, @ten_bc2 as ten_bc2

exec pr_INbctk1nExport @$tu_ngay, @$den_ngay, @$ma_kho, @$loai_du_lieu, @$ma_dvcs, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'INBCTK1N%'
]]>
    </text>
  </query>

