<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
select @$tu_ngay as date_from, @$den_ngay as date_to, @$tk as tk, case when @@language = 'v' then ten_tk else ten_tk2 end as ten_tk from dmtk where tk = @$tk
exec pr_SObccn1nExport @$tu_ngay, @$den_ngay, null, null, @$tk, @$isbalance, @$ma_dvcs, @@language, @@userID, @@admin
Update dmprint set stt_rec_key='' where ma_ct like 'SOBCCN1N%'
]]>
    </text>
  </query>
  <forms>
	
	<form id="010" reportFile="SObccn1n_110" templateFile="" commandArgument="pdf" urlImage="&p;">
      <header v="Sổ chi tiết công nợ nhiều khách hàng" e="Customers Activity"></header>
      <download>
        <header v="Sổ chi tiết công nợ nhiều khách hàng" e="Customers Activity"/>
      </download>&b;
    </form>
    <form id="020" reportFile="SObccn1n_210" templateFile="" commandArgument="pdf" urlImage="">
      <header v="Sổ chi tiết công nợ nhiều khách hàng ngoại tệ" e="Customers Activity in Foreign Currency"></header>
      <download>
        <header v="Sổ chi tiết công nợ nhiều khách hàng ngoại tệ" e="Customers Activity in Foreign Currency"/>
      </download>&f;
    </form>
	
	
	<form id="030" reportFile="SObccn1n_110a" templateFile="" commandArgument="pdf" urlImage="">
      <header v="Sổ chi tiết công nợ nhiều khách hàng (Chi tiết)" e="Customers Activity (Detail)"></header>
      <download>
        <header v="Sổ chi tiết công nợ nhiều khách hàng" e="Customers Activity"/>
      </download>&b;
    </form>
	<form id="040" reportFile="SObccn1n_210b" templateFile="" commandArgument="pdf" urlImage="">
      <header v="Sổ chi tiết công nợ nhiều khách hàng ngoại tệ (Chi tiết)" e="Customers Activity in Foreign Currency (Detaild)"></header>
      <download>
        <header v="Sổ chi tiết công nợ nhiều khách hàng ngoại tệ" e="Customers Activity in Foreign Currency"/>
      </download>&f;
    </form>
	&s;
	<form id="510" templateFile ="SObccn1n_110" commandArgument="Excel" urlImage="&e;">
		<header v="Sổ chi tiết công nợ nhiều khách hàng (Excel)" e="Customers Activity"></header>
		<download>
			<header v="Sổ chi tiết công nợ nhiều khách hàng" e="Customers Activity"/>
		</download>
	</form>
	<form id="520" templateFile ="SObccn1n_210" commandArgument="Excel" urlImage="&e;">
		<header v="Sổ chi tiết công nợ nhiều khách hàng ngoại tệ (Excel)" e="Customers Activity"></header>
		<download>
			<header v="Sổ chi tiết công nợ nhiều khách hàng" e="Customers Activity"/>
		</download>
	</form>
  </forms>

  <fields>
    <field name="title" type="String">
          <header v="SỔ CHI TIẾT CÔNG NỢ" e="CUSTOMERS ACTIVITY"/>
    </field>
    <field name="h_ct" type="String">
      <header v="Chứng từ" e="Voucher"/>
    </field>
    <field name="h_so" type="String">
      <header v="Số" e="Number"/>
    </field>
    <field name="h_ngay" type="String">
      <header v="Ngày" e="Date"/>
    </field>
    <field name="h_tu_ngay" type="String">
      <header v="Từ ngày" e="Date from"/>
    </field>
    <field name="h_den_ngay" type="String">
      <header v="đến ngày" e="to"/>
    </field>
    <field name="h_dien_giai" type="String">
      <header v="Diễn giải" e="Description"/>
    </field>
    <field name="h_co" type="String">
      <header v="Có" e="Credit"/>
    </field>
    <field name="h_no" type="String">
      <header v="Nợ" e="Debit"/>
    </field>
    <field name="h_ps" type="String">
      <header v="Số phát sinh" e="Arising"/>
    </field>
    <field name="h_ps_nt" type="String">
      <header v="Số phát sinh nt" e="FC Arising"/>
    </field>
    <field name="h_sd" type="String">
      <header v="Số dư" e="Balance"/>
    </field>
    <field name="h_sd_nt" type="String">
      <header v="Số dư nt" e="FC Balance"/>
    </field>
    <field name="h_tk_du" type="String">
      <header v="Tk đối ứng" e="Reference Account"/>
    </field>
    <field name="h_ty_gia" type="String">
      <header v="Tỷ giá" e="Exchange Rate"/>
    </field>
    <field name="h_sd_ck" type="String">
      <header v="Số dư cuối kỳ:" e="Closing Balance:"/>
    </field>
    <field name="h_sd_co_ck" type="String">
      <header v="Số dư có cuối kỳ:" e="Closing Credit Balance:"/>
    </field>
    <field name="h_sd_co_dk" type="String">
      <header v="Số dư có đầu kỳ:" e="Opening Credit Balance:"/>
    </field>
    <field name="h_sd_dk" type="String">
      <header v="Số dư đầu kỳ:" e="Opening Balance:"/>
    </field>
    <field name="h_sd_no_ck" type="String">
      <header v="Số dư nợ cuối kỳ:" e="Closing Debit Balance:"/>
    </field>
    <field name="h_sd_no_dk" type="String">
      <header v="Số dư nợ đầu kỳ:" e="Opening Debit Balance:"/>
    </field>
    <field name="h_t_ps_co" type="String">
      <header v="Tổng phát sinh có:" e="Total Credit Amount:"/>
    </field>
    <field name="h_t_ps_no" type="String">
      <header v="Tổng phát sinh nợ:" e="Total Debit Amount:"/>
    </field>
    <field name="h_t_ps" type="String">
      <header v="Tổng phát sinh:" e="Total Amount:"/>
    </field>
    <field name="h_tk" type="String">
      <header v="Tài khoản:" e="Account:"/>
    </field>
    <field name="h_kh" type="String">
      <header v="Khách hàng:" e="Customer:"/>
    </field>
    <field name="h_ten_kh" type="String">
      <header v="Tên khách hàng" e="Customer"/>
    </field>
    <field name="h_tk_du" type="String">
      <header v="Tài khoản" e="Customer"/>
    </field>
  </fields>
</report>