<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">

  <!ENTITY GLTranReport SYSTEM ".\Include\GLTranReport.xml">
  <!ENTITY GLTranReportSql SYSTEM ".\Include\GLTranReportSql.txt">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
]]>&GLTranReportSql;<![CDATA[
else begin
    declare @m_ma_nt0 varchar(10)
    select @m_ma_nt0 = val from options where name = N'm_ma_nt0' 
    select ltrim(so_ct) as so_ct,t_ps_no, t_ps_no_nt, t_ps_co, t_ps_co_nt, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, t_ps_no, @@language) as t_ps_no_in_word, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(ma_nt, t_ps_no_nt, @@language) as t_ps_no_nt_in_word,
		    dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, t_ps_co, @@language) as t_ps_co_in_word,
		    dbo.MaxvOnline$Function$System$ReadCurrency(ma_nt, t_ps_co_nt, @@language) as t_ps_co_nt_in_word,
		    replace(str(day(ngay_ct),2),' ','0') ngay, replace(str(month(ngay_ct),2),' ','0') thang, cast(year(ngay_ct) as char(4)) nam
	    from @@prime$partition$current a with(nolock)
	    where stt_rec = @stt_rec

    declare @key varchar(128)
    select @key = 'a.stt_rec = ''' + @stt_rec + ''''
    exec pr_PrintGLTran @@language, @key, 'd39$$partition$current', @@id
end
]]>
    </text>
  </query>

  <forms>
    <form id="110" reportFile="GLTran_110" templateFile=""  commandArgument="Pdf" urlImage="&p;">
      <header v="chứng từ bù trừ công nợ" e="Misc. Payable, Debit/Credit Memo"></header>
      <download>
        <header  v="Chứng từ bù trừ công nợ" e="Misc. Payable, Debit/Credit Memo"/>
      </download>&b;
    </form>
    <form id="210" reportFile="GLTran_110" templateFile=""  commandArgument="Pdf">
      <header v="Chứng từ bù trừ công nợ ngoại tệ" e="Standard Form in Foreign Currency"/>
      <download>
        <header  v="Chứng từ bù trừ công nợ ngoại tệ" e="Misc. Payable, Debit/Credit Memo in Foreign Currency"/>
      </download>&f;
    </form>

    &s;

    <form id="510" reportFile="" templateFile="GLTran_110" commandArgument="Excel" urlImage="&e;">
      <header v="Chứng từ bù trừ công nợ (Excel)" e="Misc. Payable, Debit/Credit Memo (Excel)"></header>
      <download>
        <header  v="Chứng từ bù trừ công nợ (Excel)" e="Misc. Payable, Debit/Credit Memo (Excel)"/>
      </download>&b;
    </form>
    <form id="120" reportFile="" templateFile="GLTran_210" commandArgument="Excel">
      <header v="Chứng từ bù trừ công nợ ngoại tệ" e="Misc. Payable, Debit/Credit Memo in Foreign Currency"/>
      <download>
        <header  v="Chứng từ bù trừ công nợ tiền ngoại tệ" e="Misc. Payable, Debit/Credit Memo in Foreign Currency"/>
      </download>&f;
    </form>

    &s;

    &GLTranReport;
  </forms>

  <fields>
    <field name="title" type="String">
      <header v="CHỨNG TỪ BÙ TRỪ CÔNG NỢ" e="MISC. PAYABLE, DEBIT/CREDIT MEMO"/>
    </field>
    <field name="h_so_phieu" type="String">
      <header v="Số phiếu: " e="Voucher No.: "/>
