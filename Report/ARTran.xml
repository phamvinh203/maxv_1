  <!ENTITY GLTranReportSql SYSTEM ".\Include\GLTranReportSql.txt">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
if @@form = '013' or @@form = '014' begin
	exec pr_PrintARTranMultiCopies @stt_rec, @@id, 'm21$$partition$current', 'd21$$partition$current', @@language, @@userID, @@admin
	return
end
]]>&GLTranReportSql;<![CDATA[
else begin
  declare @m_ma_nt0 varchar(10), @key varchar(128)
  select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
		  select a.ong_ba as doi_tac, a.ma_kh, e.ten_kh as ten_kh, e.ten_kh as ten_kh2, e.ma_so_thue, e.dia_chi, b.tk_nh, c.ten_ngan as thanh_toan, c.ten_ngan2 as thanh_toan2, 
			  N'1: Lưu' as so_lien, isnull(k.ky_hieu, '') ky_hieu, a.so_seri, a.so_ct, a.ngay_ct, cast(cast(d.thue_suat as int) as varchar)+'%' as thue_suat, 
			  a.ma_nt, a.t_tien2, a.t_tien_nt2, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt, 
			  dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tien2, @@language) as t_tt_in_word, 
			  dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tien_nt2, @@language) as t_tt_nt_in_word,
			  replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam,
			  a.dien_giai
		    from @@prime$partition$current a with(nolock)
				    left join dmkh b with(nolock) on a.ma_kh = b.ma_kh
				    left join dmtt c with(nolock) on a.ma_tt = c.ma_tt
				    left join d21$$partition$current d with(nolock) on (a.stt_rec = d.stt_rec and d.stt_rec0 = (select min(stt_rec0) from d21$$partition$current with(nolock) where stt_rec = a.stt_rec))
				    left join ctgt21 e with(nolock) on a.stt_rec = e.stt_rec
            left join v20dmnk k with(nolock) on a.ma_nk = k.ma_nk
		    where a.stt_rec = @stt_rec


    select @key = 'a.stt_rec = ''' + @stt_rec + ''''
    exec pr_PrintARTran @@language, @key, 'd21$$partition$current', @@id
end
]]>
    </text>
  </query>

  <forms>
	<form id="110" reportFile="ARTran_110" templateFile="" commandArgument="Pdf" urlImage="&p;">
      <header v="Hóa đơn bán hàng" e="Sales invoice"></header>
      <download>
        <header v="Hóa đơn bán hàng" e="Sales invoice"/>
