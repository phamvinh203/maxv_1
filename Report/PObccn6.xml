<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">
  
  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <forms>
    <form id="110" reportFile="SObccn6_110" commandArgument="Pdf" urlImage="&p;">
      <header v="Báo cáo số dư công nợ" e="Customer Balance Summary"></header>
      <download>
        <header v="Báo cáo số dư công nợ" e="Customer Balance Summary"/>
      </download>
    </form>

    <form id="210" reportFile="SObccn6_210" commandArgument="Pdf">
      <header v="Báo cáo số dư công nợ tiền ngoại tệ" e="Customer Balance Summary in Foreign Currency"/>
      <download>
        <header v="Báo cáo số dư công nợ tiền ngoại tệ" e="Customer Balance Summary in Foreign Currency"/>
      </download>
    </form>

    &s;
    <form id="510" templateFile="SObccn6_110" commandArgument="Excel" urlImage="&e;" rowFilter="[2$sysprint = 1]">
      <header v="Báo cáo số dư công nợ (Excel)" e="Customer Balance Summary (Excel)"></header>
      <download>
        <header v="Báo cáo số dư công nợ (Excel)" e="Customer Balance Summary (Excel)"/>
      </download>&b;
    </form>

    <form id="610" templateFile="SObccn6_210" commandArgument="Excel" rowFilter="[2$sysprint = 1]">
      <header v="Báo cáo số dư công nợ ngoại tệ (Excel)" e="Customer Balance Summary in Foreign Currency (Excel)"></header>
      <download>
        <header v="Báo cáo số dư công nợ ngoại tệ (Excel)" e="Customer Balance Summary in Foreign Currency (Excel)"/>
      </download>&f;
    </form>
  </forms>

  <fields>
    <field name="title" type="String">
      <header v="BÁO CÁO SỐ DƯ CÔNG NỢ" e="SUPPLIER BALANCE SUMMARY"/>
    </field>
    <field name="h_tu_ngay" type="String">
      <header v="Ngày:" e="Date:"/>
    </field>
    <field name="h_tk" type="String">
      <header v="Tài khoản:" e="Account:"/>
    </field>
    <field name="h_stt" type="String">
      <header v="Stt" e="No."/>
    </field>
    <field name="h_ma_kh" type="String">
      <header v="Mã khách" e="Customer ID"/>
    </field>
    <field name="h_ten_kh" type="String">
      <header v="Tên khách" e="Customer Name"/>
    </field>
    <field name="h_so_du" type="String">
      <header v="Số dư" e="Balance"/>
    </field>
    <field name="h_nt" type="String">
      <header v="nt" e="FC"/>
    </field>
    <field name="h_no" type="String">
      <header v="Nợ" e="Debit"/>
    </field>
    <field name="h_co" type="String">
      <header v="Có" e="Credit"/>
    </field>
  </fields>
</report>