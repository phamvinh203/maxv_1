  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
]]>&GLTranReportSql;<![CDATA[
else begin
    declare @m_ma_nt0 varchar(10)
	declare @ma_tt nvarchar(16), @so_tt nvarchar(255), @so_tt2 nvarchar(255), @ngay_tt nvarchar(255), @ngay_tt2 nvarchar(255), @ten_bc nvarchar(255), @ten_bc2 nvarchar(255)
     select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
	select @ma_tt = rtrim(ltrim(val)) from options where name='r_cdkt'
	select @so_tt=so_tt, @so_tt2 = so_tt2, @ngay_tt = ngay_tt, @ngay_tt2 = ngay_tt2 from report1 where ma_tt=@ma_tt 
	select @ten_bc = ten_bc, @ten_bc2=ten_bc2 from report2 where ma_tt=@ma_tt and sysid='IRTran'
	
    -- Lay tk_vt trong dmvt cach nhau bang dau ','
        create table #dmtkvt(tk_vt nvarchar(64))
        insert into #dmtkvt select distinct tk_vt from @@prime$partition$current a with(nolock)
		    left join d73$$partition$current b with(nolock) on (a.stt_rec = b.stt_rec) where a.stt_rec = @stt_rec
	   
        declare @tk_vt nvarchar(64) = ''
        select @tk_vt = @tk_vt + ',' + LTRIM(RTRIM(tk_vt)) from #dmtkvt
        select @tk_vt = RIGHT(@tk_vt, LEN(@tk_vt) - 1)
        drop table #dmtkvt
     
    select a.ong_ba,rtrim(a.ma_kh)as ma_kh, b.ten_kh, b.ten_kh2, b.dia_chi, ltrim(a.so_ct) so_ct, ltrim(d.so_ct0) so_ct0, d.ngay_ct0,d.so_seri0, 
		    rtrim(a.tk) tk, isnull(c.ten_tk,'') ten_tk, isnull(c.ten_tk2,'') ten_tk2, a.t_cp, a.t_cp_nt, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tt, @@language) as t_tien_in_word, 
		    dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tt_nt, @@language) as t_tien_nt_in_word,
		    replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam,
        @tk_vt as tk_vt, a.dien_giai, @so_tt as so_tt, @so_tt2 as so_tt2, @ngay_tt as ngay_tt, @ngay_tt2 as ngay_tt2, @ten_bc as ten_bc, @ten_bc2 as ten_bc2
	    from @@prime$partition$current a with(nolock)
		    left join dmkh b with(nolock) on a.ma_kh = b.ma_kh 
		    left join dmtk c with(nolock) on a.tk = c.tk 
			left join (select stt_rec, max(so_ct0) as so_ct0, max(ngay_ct0) as ngay_ct0, max(so_seri0) as so_seri0 from r30$$partition$current group by stt_rec) d on a.stt_rec = d.stt_rec
	    where a.stt_rec = @stt_rec
    		
    declare @key varchar(128)
    select @key = 'a.stt_rec = ''' + @stt_rec + ''''
    exec pr_PrintPFTran @@language, @key, 'd73$$partition$current', @@id
end
]]>
    </text>
  </query>

