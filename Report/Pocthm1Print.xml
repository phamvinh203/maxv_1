declare @formTypePV tinyint

if @@form in ('150','160') begin
	exec pr_Pocthm1PCPrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs, '1', @@language, @@userID, @@admin
	Update dmprint set stt_rec_key='' where ma_ct like 'HM1%'
	end
else
	begin
		exec pr_Pocthm1PrintExport @$ngay_ct1, @$ngay_ct2, @$ma_dvcs  , 0, 1, @@language, @@userID, @@admin, '@@sysDatabaseName'
		Update dmprint set stt_rec_key='' where ma_ct like 'HM1%'
	end

]]>
