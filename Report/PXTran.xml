<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE report [
  <!ENTITY b SYSTEM ".\Include\BaseCurrency.xml">
  <!ENTITY f SYSTEM ".\Include\ForeignCurrency.xml">
  <!ENTITY s SYSTEM ".\Include\Separate.xml">

  <!ENTITY d SYSTEM ".\Include\Download\SVTran.xml">
  <!ENTITY p "../images/pdf.gif">
  <!ENTITY e "../images/excel.gif">

  <!ENTITY GLTranReport SYSTEM ".\Include\GLTranReport.xml">
  <!ENTITY GLTranReportSql SYSTEM ".\Include\GLTranReportSql.txt">
]>

<report xmlns="urn:schemas-maxv-com:data-report">
  <query>
    <text>
      <![CDATA[
if dbo.MaxvOnline$Function$CheckSQLInjection(@stt_rec) = 0 return
]]>&GLTranReportSql;<![CDATA[
else begin
    declare @m_ma_nt0 varchar(10), @key varchar(128)
    select @m_ma_nt0 = val from options where name = N'm_ma_nt0'
 
        select case when a.ong_ba <> '' then rtrim(a.ong_ba) else '' end as ong_ba,
            rtrim(a.ma_kh) as ma_kh, case when @@language = 'V' then rtrim(b.ten_kh) else rtrim(b.ten_kh2) end as ten_kh, 
            rtrim(b.dia_chi) as dia_chi, rtrim(a.dien_giai) as dien_giai, a.so_seri, ltrim(a.so_ct) so_ct, 
            rtrim(a.tk) as tk, case when @@language = 'V' then rtrim(c.ten_tk) else rtrim(c.ten_tk2) end as ten_tk, 
            a.t_tien as t_tien2, a.t_tien_nt as t_tien_nt2, a.t_thue, a.t_thue_nt, a.t_tt, a.t_tt_nt,
		        dbo.MaxvOnline$Function$System$ReadCurrency(@m_ma_nt0, a.t_tt, @@language) as t_tt_in_word, 
		        dbo.MaxvOnline$Function$System$ReadCurrency(a.ma_nt, a.t_tt_nt, @@language) as t_tt_nt_in_word,
		        replace(str(day(a.ngay_ct),2),' ','0') ngay, replace(str(month(a.ngay_ct),2),' ','0') thang, cast(year(a.ngay_ct) as char(4)) nam
	        from m26$000000 a with(nolock)
		        left join dmkh b with(nolock) on a.ma_kh = b.ma_kh		        
		        left join dmtk c with(nolock) on a.tk = c.tk            
	        where a.stt_rec = @stt_rec

        select @key = 'a.stt_rec = ''' + @stt_rec + ''''
        exec pr_PrintPXTran @@language, @key, 'd26$000000', @@id
end
		]]>
    </text>
  </query>

  <forms>

    <form id="110" reportFile ="PXTran_110" commandArgument="Pdf" urlImage="&p;">
      <header v="Hóa đơn dịch vụ trả lại nhà cung cấp" e="Service Return to Supplier" />
      <download>
        <header v="Hóa đơn dịch vụ trả lại nhà cung cấp" e="Service Return to Supplier"/>
      </download>&b;
    </form>
    <form id="210" reportFile ="PXTran_110" commandArgument="Pdf">
      <header v="Hóa đơn dịch vụ trả lại nhà cung cấp ngoại tệ" e="Service Return to Supplier in Foreign Currency" />
      <download>
        <header v="Hóa đơn dịch vụ trả lại nhà cung cấp ngoại tệ" e="Service Return to Supplier in Foreign Currency"/>
      </download>&f;
    </form>

    &s;
    <form id="510" reportFile="" templateFile="PXTran_110" commandArgument="Excel" urlImage="&e;">
      <header v="Hóa đơn dịch vụ trả lại nhà cung cấp (Excel)" e="Service Return to Supplier (Excel)"></header>
      <download>
        <header  v="Hóa đơn dịch vụ trả lại nhà cung cấp (Excel)" e="Service Return to Supplier (Excel)"/>
      </download>&b;
    </form>
    <form id="610" reportFile="" templateFile="PXTran_210" commandArgument="Excel">
      <header v="Hóa đơn dịch vụ trả lại nhà cung cấp ngoại tệ (Excel)" e="Service Return to Supplier in Foreign Currency"/>
      <download>
        <header  v="Hóa đơn dịch vụ trả lại nhà cung cấp ngoại tệ (Excel)" e="Service Return to Supplier in Foreign Currency"/>
      </download>&f;
    </form>


    &s;

    &GLTranReport;
  </forms>

  <fields>
    <field name="title" type="String">
      <header v="HÓA ĐƠN DỊCH VỤ TRẢ LẠI NHÀ CUNG CẤP" e="SERVICE RETURN TO SUPPLIER"/>
    </field>
     <field name="h_ht_nguoi_giao_hang" type ="String">
      <header v="Họ tên người giao hàng:" e="Deliverer:"/>
    </field>
    <field name="h_don_vi" type ="String">
      <header v="Đơn vị:" e="Company:"/>
    </field>
    <field name="h_dia_chi" type ="String">
      <header v="Địa chỉ:" e="Address:"/>
    </field>
    <field name="h_tk_no" type ="String">
      <header v="Tài khoản nợ:" e="Credit Account:"/>
    </field>
    <field name="h_so_phieu" type ="String">
      <header v="Số phiếu:" e="Voucher No.:"/>
    </field>
    <field name="h_dien_giai" type ="String">
      <header v="Diễn giải" e="Description"/>
    </field>
    <field name="h_tk" type ="String">
      <header v="Tài khoản có" e="Debit Account"/>
    </field>
    <field name="h_tien" type ="String">
      <header v="Tiền" e="Amount"/>
    </field>
    <field name="h_hyphen" type ="String">
      <header v="-" e="-"/>
    </field>
    <field name="h_space" type ="String">
      <header v=" " e=" "/>
    </field>
    <field name="h_t_tien" type ="String">
      <header v="Tổng cộng tiền hàng" e="Total Amount"/>
    </field>
    <field name="h_t_thue" type ="String">
      <header v="Tổng cộng tiền thuế" e="Total VAT"/>
    </field>
    <field name="h_tong_cong" type ="String">
      <header v="Tổng cộng" e="Total"/>
    </field>
    <field name="h_xac_nhan" type ="String">
      <header v="Số tiền (viết bằng chữ):" e="Amount (in Words):"/>
    </field>
  </fields>
</report>