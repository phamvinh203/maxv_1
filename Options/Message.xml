</table>
<table class="ts" border="0" cellpadding="1" cellspacing="1">
<tr class="h"><td style="width:120px;text-align:left;color:#FF3300;">{!h_clink}</td><td class="r4" style="color:#FF3300;"><a href="{!clink}" style="color:#FF3300;" target="_blank">{!h_cancel}</a></td></tr>
</table>
