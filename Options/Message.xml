      <action id="PurchaseRequisition" table="m91$000000" v="Phiếu nhu cầu vật tư chờ duyệt" e="Purchase requisition waiting for approval">
        <fields>
          <field name="h_so_ct">
            <header v="Số phiếu" e="Number"/>
          </field>
          <field name="h_ngay_ct">
            <header v="Ngày" e="Date"/>
          </field>
          <field name="h_dien_giai">
            <header v="Diễn giải" e="Memo"/>
          </field>
          <field name="h_alink">
            <header v="Đường dẫn duyệt" e="Link for approval"/>
          </field>
          <field name="h_clink">
            <header v="Đường dẫn hủy" e="Link for cancellation"/>
          </field>
          <field name="h_vat_tu">
            <header v="Mã hàng" e="Item"/>
          </field>
          <field name="h_ten_vt">
            <header v="Tên mặt hàng" e="Item Description"/>
          </field>
          <field name="h_dvt">
            <header v="Đvt" e="UOM"/>
          </field>
          <field name="h_approve">
            <header v="Duyệt phiếu nhu cầu vật tư" e="Approve"/>
          </field>
          <field name="h_cancel">
            <header v="Hủy phiếu nhu cầu vật tư" e="Cancel"/>
          </field>
          <field name="so_luong">
            <header v="Số lượng" e="Quantity"/>
          </field>
          <field name="h_gia">
            <header v="Đơn giá" e="Price"/>
          </field>
          <field name="h_tien">
            <header v="Thành tiền" e="Amount"/>
          </field>
          <field name="h_t_tien">
            <header v="Tổng tiền" e="Total Amount"/>
          </field>
          <field name="h_in_words">
            <header v="Bằng chữ" e="In Words"/>
          </field>
        </fields>

        <messages>
          <state id="complete">
            <label v="Chương trình đã thực hiện xong." e="The process completed successfully."/>
          </state>
          <state id="invalid">
            <label v="Phiếu yêu cầu này đã được duyệt, hủy hoặc thay đổi thông tin." e="This purchase requisition has been approved, canceled or changed by another user."/>
          </state>
        </messages>

        <query id="report">
          <command id="master">
            <text>
              <![CDATA[
select ltrim(so_ct) as so_ct, ma_nt, convert(varchar(12), b.ngay_ct, 103) as ngay_ct,
    convert(varchar(32), b.datetime2, 121) as datetime2, dien_giai, dien_thoai, e_mail, d_language,
    upper(ma_nhan) as ma_nhan, upper(ma_huy) as ma_huy
  from @@sysDatabaseName..userinfo2 a, @@table b, dmxn c
  where a.id in (select user_id3 from @@table where stt_rec = @@stt_rec) and b.stt_rec = @@stt_rec and b.stt_rec = c.stt_rec
]]>
            </text>
          </command>
          <command id="detail">
            <text>
              <![CDATA[
select a.ma_vt, case @@language when 'v' then b.ten_vt else b.ten_vt2 end as ten_vt, a.dvt,
    cast(so_luong as varchar) as so_luong, cast(gia_nt as varchar) as gia, cast(tien_nt as varchar) as tien
  from @@table a left join dmvt b on a.ma_vt = b.ma_vt where stt_rec = @@stt_rec order by a.stt_rec0
]]>
            </text>
          </command>
          <command id="footer">
            <text>
              <![CDATA[
select cast(t_tien_nt as varchar) as t_tt_nt from @@table where stt_rec = @@stt_rec
]]>
            </text>
          </command>
        </query>

        <query id="process">
          <command id="approve">
            <text>
              <![CDATA[
declare @userID numeric(5, 0)
select @userID = user_id3 from @@table where stt_rec = @@stt_rec
delete @@sysDatabaseName..dbxn where code in (select ma_nhan from dmxn where stt_rec = @@stt_rec)
delete @@sysDatabaseName..dbxn where code in (select ma_huy from dmxn where stt_rec = @@stt_rec)
exec rs_PostPRAuthorizeDetails 1, @userID, 2, @@stt_rec, '', 0, ''
exec rs_PostPRAuthorizeHeaders @userID, '1', @@stt_rec
]]>
            </text>
          </command>
          <command id="cancel">
            <text>
              <![CDATA[
declare @userID numeric(5, 0)
select @userID = user_id3 from @@table where stt_rec = @@stt_rec
delete @@sysDatabaseName..dbxn where code in (select ma_nhan from dmxn where stt_rec = @@stt_rec)
delete @@sysDatabaseName..dbxn where code in (select ma_huy from dmxn where stt_rec = @@stt_rec)
exec rs_PostPRAuthorizeHeaders @userID, '2', @@stt_rec
]]>
            </text>
          </command>
        </query>

